# SSH Bastion configuration for hpc101-platform
#
# Security model: cert-only authentication via platform CA.
# No passwords, no raw public keys (AuthorizedKeysFile none),
# no gateway ports, no shell on bastion.
#
# Per-student container target binding is enforced by
# AuthorizedPrincipalsCommand, which queries the platform
# lease store and returns "permitopen=\"host:port\" <principal>".
# permitopen is an authorized_keys / AuthorizedPrincipalsCommand option —
# it is a valid sshd mechanism, unlike certificate critical options.

Port 2222
ListenAddress 0.0.0.0
Protocol 2

# Host key
HostKey /etc/ssh/ssh_host_ed25519_key

# Authentication: certificates only
TrustedUserCAKeys /etc/ssh/ca.pub
PubkeyAuthentication yes
PasswordAuthentication no
ChallengeResponseAuthentication no
PermitEmptyPasswords no

# Disable authorized_keys file — only certificates
AuthorizedKeysFile none

# AuthorizedPrincipalsCommand queries the platform lease store
# to find the student's active container and returns:
#   permitopen="<container_host>:<port>" <principal>
# The %u token is replaced with the username (principal from cert).
AuthorizedPrincipalsCommand /usr/local/bin/bastion-principals %i
AuthorizedPrincipalsCommandUser nobody

# Logging
SyslogFacility AUTH
LogLevel VERBOSE

# Forwarding
AllowTcpForwarding yes
GatewayPorts no
# Default: no forwarding targets. AuthorizedPrincipalsCommand returns
# permitopen entries that allow specific container targets.
PermitOpen none

# Disable everything else
X11Forwarding no
AllowAgentForwarding no
PermitTTY no
# No interactive shell (also enforced per-cert via force-command)
ForceCommand /bin/false

# Session limits
MaxSessions 10
MaxStartups 10:30:100
ClientAliveInterval 60
ClientAliveCountMax 3

# Misc
UseDNS no
PrintMotd no
